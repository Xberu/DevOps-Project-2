# Local .terraform directories
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform plan files
*.tfplan
s3plan*

# Crash logs
crash.log

# Variable files containing secrets
# *.tfvars => Commented out to allow users to keep their variable definitions in version control if they choose to do so. Uncomment the line below to ignore all .tfvars files.
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc

# Ignore .env files if they contain sensitive information
.env

# NOTE: .terraform.lock.hcl SHOULD be committed to version control
# It ensures consistent provider versions across the team and CI/CD